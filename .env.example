# ─── Database (your local pgAdmin / PostgreSQL) ──────────────────────
# PostgreSQL runs on your machine — Docker does NOT manage it.
# Just point this at the server you already have in pgAdmin.
#
# Running api/worker LOCALLY:
#   DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/swe_agent
#
# Running api/worker INSIDE Docker (Docker Desktop):
#   DATABASE_URL=postgresql://postgres:yourpassword@host.docker.internal:5432/swe_agent
#
# Running api/worker INSIDE Docker (Linux, no Docker Desktop):
#   DATABASE_URL=postgresql://postgres:yourpassword@172.17.0.1:5432/swe_agent
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/swe_agent

# ─── Security ────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
SECRET_KEY=change-this-to-a-random-64-char-string-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Celery / Redis ──────────────────────────────────────────────────
# LOCAL:  redis://localhost:6379/0
# DOCKER: override is injected by docker-compose
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── Neo4j ───────────────────────────────────────────────────────────
# LOCAL:  bolt://localhost:7687
# DOCKER: override is injected by docker-compose
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=repomind_graph

# ─── Repos storage ───────────────────────────────────────────────────
# LOCAL:  any absolute path on your machine, e.g. C:/repomind-repos
# DOCKER: /repos  (mapped to the repomind_repos_data volume)
REPOS_BASE_PATH=C:/repomind-repos

# ─── CORS ────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:8000"]

# ─── Ollama (local LLM — run natively, not in Docker) ────────────────
# LOCAL:  http://localhost:11434
# DOCKER: http://host.docker.internal:11434  (Docker Desktop injects this hostname)
#         On Linux Docker (not Desktop): use your host's LAN IP instead,
#         e.g. http://172.17.0.1:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_DESC_MODEL=qwen2.5-coder:0.5b
